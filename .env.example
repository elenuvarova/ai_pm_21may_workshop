PORT=3001
NODE_ENV=development

# Leave DATABASE_URL unset locally — the backend falls back to a SQLite file (./data.sqlite).
# On Render, this is injected automatically from the managed Postgres instance.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Required for the "Why?" button. Get one at https://console.anthropic.com
# Without it, /api/explain returns 503 and the frontend shows a placeholder.
ANTHROPIC_API_KEY=
